# ==========================================
# 1. PyCharm IDE 配置 (必须忽略，否则别人下载后全是错误)
# ==========================================
.idea/
*.iml
*.ipr
*.iws

# ==========================================
# 2. 虚拟环境 (venv)
# ==========================================
# 忽略整个虚拟环境文件夹（这是最大的文件夹，绝对不能提交）
_venv/
venv/
env/

# ==========================================
# 3. Python 生成文件
# ==========================================
__pycache__/
*.py[cod]
*$py.class
.pytest_cache/

# ==========================================
# 4. 环境变量与敏感信息 (必须忽略，防止泄露 API Key)
# ==========================================
.env
.env.local
.env.*.local
*.env backup

# ==========================================
# 5. 日志与数据库
# ==========================================
*.log
*.db
*.sqlite3

# ==========================================
# 6. 前端相关 (如果你的 frontend 里有 node_modules)
# ==========================================
/frontend/node_modules/

# ==========================================
# 7. 其他
# ==========================================
.DS_Store
Thumbs.db